<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?attr/appBackgroundColor"
    android:padding="0dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_root"
        android:background="?attr/appBackgroundColor"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <ImageButton
            android:id="@+id/backButton"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/my_back"
            android:contentDescription="Menu"
            android:layout_marginStart="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:id="@+id/titleContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnExportSummary"
            app:layout_constraintStart_toEndOf="@+id/backButton"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Summary"
                android:textColor="?attr/appPrimaryColor"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class Name"
                android:textColor="@color/nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
        <ImageButton
            android:id="@+id/btnExportSummary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/my_download"
            android:layout_marginEnd="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/appPrimaryColor"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/header_rounded"
        android:paddingTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <!-- Class selection removed: summary now uses selected class from ViewModel or navigation args -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:weightSum="2">
                <TextView
                    android:gravity="center"
                    android:id="@+id/tvFromDate"
                    android:background="@drawable/bg_capsule"
                    android:padding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="From"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:textColor="@color/text_hint_grey"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" To "/>
                <TextView
                    android:gravity="center"
                    android:id="@+id/tvToDate"
                    android:background="@drawable/bg_capsule"
                    android:padding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="To"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center_vertical"
                android:id="@+id/btnSort"
                android:padding="0dp"
                android:layout_width="wrap_content"
                android:layout_height="27dp"
                android:layout_marginBottom="3dp"
                android:text="Sort "
                android:drawablePadding="8dp"
                app:drawableStartCompat="@drawable/my_sort"
                app:drawableTint="?attr/appPrimaryColor"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:background="?attr/appBackgroundColor"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="46dp">
            <TextView
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Roll No."
                android:maxLines="1"/>
            <TextView
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Name"
                android:layout_weight="1"
                android:paddingStart="8dp"/>
            <TextView
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="Present"/>
            <TextView
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="Absent"/>
            <TextView
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="%"/>
        </LinearLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSummary"
                android:paddingBottom="80dp"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <TextView
                android:textColor="@color/text_medium_grey"
                android:layout_gravity="center"
                android:id="@+id/tvEmptySummary"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No data to show."/>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
