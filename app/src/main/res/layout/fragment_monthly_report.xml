<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?attr/appBackgroundColor"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="?attr/appBackgroundColor"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <ImageButton
            android:id="@+id/backButton"
            android:background="@android:color/transparent"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/my_back"
            android:layout_marginStart="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:id="@+id/titleContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/backButton"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly Report"
                android:textColor="?attr/appPrimaryColor"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class Name"
                android:textColor="@color/nav_unselected"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/header_rounded"
        android:paddingTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            <TextView
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center"
                android:id="@+id/btnMonthPicker"
                android:background="@drawable/bg_capsule"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:text="Select Month"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"/>
            <ImageButton
                android:id="@+id/btnExport"
                android:background="@drawable/bg_capsule"
                android:padding="12dp"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/my_download"
                android:scaleType="fitCenter"
                app:tint="?attr/appPrimaryColor"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:background="?attr/appBackgroundColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textStyle="bold"
                    android:textColor="?attr/appPrimaryColor"
                    android:gravity="center"
                    android:padding="4dp"
                    android:layout_width="80dp"
                    android:layout_height="50dp"
                    android:text="Roll No."/>
                <HorizontalScrollView
                    android:id="@+id/hsvHeader"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/headerContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </HorizontalScrollView>
            </LinearLayout>
            <ScrollView
                android:id="@+id/verticalScroll"
                android:paddingBottom="50dp"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/rollNoContainer"
                        android:background="?attr/appBackgroundColor"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"/>
                    <HorizontalScrollView
                        android:id="@+id/hsvContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/contentContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </HorizontalScrollView>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
