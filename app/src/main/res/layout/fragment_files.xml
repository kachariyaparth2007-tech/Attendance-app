<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/appBackgroundColor"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentTop="true">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header_root"
            android:background="?attr/appBackgroundColor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">
            <ImageButton
                android:id="@+id/backButton"
                android:background="@android:color/transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/my_back"
                android:layout_marginStart="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:gravity="center_vertical"
                android:id="@+id/header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Files"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/backButton"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/layout_action_mode"
            android:background="?attr/appBackgroundColor"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            <ImageView
                android:id="@+id/action_close"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/my_close"
                app:tint="?attr/appPrimaryColor"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/appPrimaryColor"
                android:id="@+id/action_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="0 Selected"
                android:layout_weight="1"
                android:paddingStart="16dp"/>
            <ImageView
                android:id="@+id/action_rename"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/my_edit"
                android:layout_marginEnd="20dp"
                app:tint="?attr/appPrimaryColor"/>
            <ImageView
                android:id="@+id/action_share"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/my_share"
                android:layout_marginEnd="20dp"
                app:tint="?attr/appPrimaryColor"/>
            <ImageView
                android:id="@+id/action_delete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete"
                app:tint="?attr/appPrimaryColor"/>
        </LinearLayout>
    </FrameLayout>
    <RelativeLayout
        android:background="@drawable/header_rounded"
        android:paddingTop="4dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/header_container">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewFiles"
            android:paddingBottom="60dp"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <TextView
            android:id="@+id/txtNoFiles"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No files found in Documents/ATTND"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
</RelativeLayout>
